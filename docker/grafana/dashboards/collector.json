{
  "dashboard": {
    "id": null,
    "uid": "collector-overview",
    "title": "源画像库 — 采集系统监控",
    "tags": ["collector", "源画像库"],
    "timezone": "Asia/Shanghai",
    "refresh": "30s",
    "time": { "from": "now-6h", "to": "now" },
    "panels": [
      {
        "id": 1,
        "title": "采集成功率 (近1小时)",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 0 },
        "targets": [{ "expr": "sum(rate(crawl_tasks_total{status='success'}[1h])) / sum(rate(crawl_tasks_total[1h])) * 100" }],
        "fieldConfig": {
          "defaults": {
            "unit": "percent",
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 80 },
                { "color": "green", "value": 95 }
              ]
            },
            "min": 0, "max": 100
          }
        }
      },
      {
        "id": 2,
        "title": "队列积压",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 6, "y": 0 },
        "targets": [
          { "expr": "queue_pending_tasks{queue_type='http'}", "legendFormat": "HTTP队列" },
          { "expr": "queue_pending_tasks{queue_type='browser'}", "legendFormat": "Browser队列" }
        ]
      },
      {
        "id": 3,
        "title": "Worker 内存使用",
        "type": "timeseries",
        "gridPos": { "h": 6, "w": 6, "x": 12, "y": 0 },
        "targets": [{ "expr": "worker_memory_bytes", "legendFormat": "{{worker_id}}" }],
        "fieldConfig": { "defaults": { "unit": "bytes" } }
      },
      {
        "id": 4,
        "title": "活跃 Worker 数",
        "type": "stat",
        "gridPos": { "h": 6, "w": 6, "x": 18, "y": 0 },
        "targets": [
          { "expr": "worker_active_count{worker_type='http'}", "legendFormat": "HTTP" },
          { "expr": "worker_active_count{worker_type='browser'}", "legendFormat": "Browser" }
        ]
      },
      {
        "id": 5,
        "title": "采集任务数 (按模板)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 6 },
        "targets": [{ "expr": "rate(crawl_tasks_total{status='success'}[5m])", "legendFormat": "{{template}}" }],
        "fieldConfig": { "defaults": { "unit": "ops" } }
      },
      {
        "id": 6,
        "title": "采集耗时分布 (按模板)",
        "type": "heatmap",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 6 },
        "targets": [{ "expr": "rate(crawl_duration_seconds_bucket[5m])", "legendFormat": "{{template}}" }]
      },
      {
        "id": 7,
        "title": "新增文章数 (按模板)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 14 },
        "targets": [{ "expr": "rate(crawl_articles_new_total[5m])", "legendFormat": "{{template}}" }],
        "fieldConfig": { "defaults": { "unit": "short" } }
      },
      {
        "id": 8,
        "title": "LLM 检测耗时",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 14 },
        "targets": [
          { "expr": "rate(llm_detect_total{status='success'}[5m])", "legendFormat": "成功" },
          { "expr": "rate(llm_detect_total{status='failed'}[5m])", "legendFormat": "失败" },
          { "expr": "histogram_quantile(0.95, rate(llm_detect_duration_seconds_bucket[5m]))", "legendFormat": "P95 耗时" }
        ]
      },
      {
        "id": 9,
        "title": "调度轮次 (v1.0)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 0, "y": 22 },
        "targets": [
          { "expr": "rate(schedule_round_total{period='work'}[1h])", "legendFormat": "工作时间" },
          { "expr": "rate(schedule_round_total{period='off_hour'}[1h])", "legendFormat": "非工作时间" },
          { "expr": "rate(schedule_round_total{period='manual'}[1h])", "legendFormat": "手动触发" }
        ]
      },
      {
        "id": 10,
        "title": "反爬尝试 (v1.0)",
        "type": "timeseries",
        "gridPos": { "h": 8, "w": 12, "x": 12, "y": 22 },
        "targets": [
          { "expr": "rate(antibot_attempts_total{status='success'}[5m])", "legendFormat": "{{tier}} 成功" },
          { "expr": "rate(antibot_attempts_total{status='failed'}[5m])", "legendFormat": "{{tier}} 失败" }
        ]
      },
      {
        "id": 11,
        "title": "更新检测跳过率 (v1.0)",
        "type": "gauge",
        "gridPos": { "h": 6, "w": 6, "x": 0, "y": 30 },
        "targets": [{ "expr": "update_check_skip_rate" }],
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "thresholds": {
              "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 0.6 },
                { "color": "green", "value": 0.8 }
              ]
            },
            "min": 0, "max": 1
          }
        }
      }
    ]
  },
  "overwrite": true
}
