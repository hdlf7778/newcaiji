# ============================================================
# 源画像库 — 环境变量模板
# 复制为 .env 并填写实际值: cp .env.example .env
#
# !! 重要：必须将所有 CHANGE_ME 替换为实际强密码 !!
# 生成随机密码: openssl rand -base64 16
# 生成 JWT 密钥: openssl rand -base64 64
# ============================================================

# MySQL
DB_ROOT_PASSWORD=CHANGE_ME_strong_root_password
DB_NAME=collector
DB_USERNAME=root
DB_PASSWORD=CHANGE_ME_strong_root_password
DB_HOST=mysql
DB_PORT=3306

# Redis
REDIS_PASSWORD=CHANGE_ME_strong_redis_password
REDIS_HOST=redis
REDIS_PORT=6379

# JWT（至少 64 字符）
JWT_SECRET=CHANGE_ME_generate_with_openssl_rand_base64_64

# LLM（豆包大模型，可选）
LLM_API_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=
LLM_MODEL=ep-20260328081539-wq277

# Python Worker API
WORKER_API_URL=http://worker-api:8001

# Worker 并发
HTTP_CONCURRENCY=15
BROWSER_CONCURRENCY=5

# Prometheus
METRICS_PORT=9090

# Grafana
GRAFANA_ADMIN_PASSWORD=CHANGE_ME_strong_grafana_password
