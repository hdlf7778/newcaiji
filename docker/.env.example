# ============================================================
# 源画像库 — 环境变量模板
# 复制为 .env 并填写实际值: cp .env.example .env
# ============================================================

# MySQL
DB_ROOT_PASSWORD=collector123
DB_NAME=collector
DB_USERNAME=root
DB_PASSWORD=collector123
DB_HOST=mysql
DB_PORT=3306

# Redis
REDIS_PASSWORD=collector_redis
REDIS_HOST=redis
REDIS_PORT=6379

# JWT
JWT_SECRET=change-me-in-production-at-least-64-chars-long-for-hs512-algorithm

# LLM（豆包大模型）
LLM_API_URL=https://ark.cn-beijing.volces.com/api/v3
LLM_API_KEY=your-api-key-here
LLM_MODEL=doubao-1-5-pro-32k

# Python Worker API
WORKER_API_URL=http://worker-api:8001

# Worker 并发
HTTP_CONCURRENCY=15
BROWSER_CONCURRENCY=5

# Prometheus
METRICS_PORT=9090
